{
  "name": "educational-design-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node scripts/clean-next.mjs",
    "dev": "next dev",
    "build": "npm run clean:next && next build",
    "preview": "node scripts/preview-export.mjs",
    "start": "npm run preview",
    "lint": "eslint .",
    "typecheck": "npm run clean:next && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:install": "playwright install chromium",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "npm run build && lhci autorun"
  },
  "dependencies": {
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.24",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.1.7",
    "jsdom": "^27.0.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}